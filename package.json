{
  "name": "codex-bridge",
  "version": "1.0.0",
  "description": "Zero-dependency local proxy: translates OpenAI Responses API to Chat Completions for DeepSeek, Xiaomi MiMo, and OpenAI behind a single base_url",
  "main": "proxy.mjs",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env proxy.mjs",
    "smoke": "./scripts/smoke.sh",
    "docker:build": "docker build -t codex-bridge:latest .",
    "docker:publish": "./scripts/docker-publish.sh"
  },
  "keywords": [
    "codex",
    "codex-cli",
    "deepseek",
    "deepseek-v4",
    "mimo",
    "openai",
    "proxy",
    "responses-api",
    "chat-completions"
  ],
  "license": "MIT",
  "optionalDependencies": {
    "redis": "^4.7.0"
  }
}
