# codex-bridge — environment variables
# Copy to .env and fill in your values. .env is in .gitignore and won't be committed.

# === Inbound auth ===
#
# Two modes, pick one or both (at least one recommended, otherwise the proxy is
# open to all processes on localhost):
#
#   PROXY_AUTH_KEY  — single key, no provider lock (simplest setup)
#   PROXY_KEYS     — multi-key table, each key optionally locked to a provider
#
# Generate a key (48-char hex):
#   openssl rand -hex 24
#   node -e "console.log('sk-proxy-local-' + require('crypto').randomBytes(24).toString('hex'))"
#
# Single-key mode (simplest):
PROXY_AUTH_KEY=sk-proxy-local-replace-with-48-char-hex
#
# Multi-key mode (recommended for multi-profile setups):
# Each key followed by ":<provider>". Provider must be deepseek / mimo / openai / * (* = any).
# PROXY_KEYS=sk-proxy-deepseek-aaa:deepseek,sk-proxy-mimo-bbb:mimo,sk-proxy-all-ccc:*

# === DeepSeek ===
# DeepSeek API key from https://platform.deepseek.com
# Required for DeepSeek model routing.
DEEPSEEK_API_KEY=your-deepseek-key-here

# === Xiaomi MiMo ===
# Xiaomi MiMo API key from https://platform.xiaomimimo.com/#/console/api-keys
# Required only if you want to route MiMo models through the proxy.
# MIMO_API_KEY=your-mimo-key-here

# === OpenAI (optional) ===
# OpenAI API key from https://platform.openai.com/api-keys
# Needed only if you want the proxy to route some models directly to OpenAI.
# OPENAI_API_KEY=your-openai-key-here

# === GitHub (optional) ===
# Optional: GitHub token for authenticated API calls (prevents 404 on private repos & rate limits).
# If unset, the proxy lazily runs `gh auth token` on first github.com fetch.
# GITHUB_TOKEN=your-github-token-here

# === Optional: Override defaults ===
# PROXY_PORT=4000
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEFAULT_PROVIDER=deepseek    # one of: deepseek, mimo, openai

# === Optional: Model lists (advertised via /v1/models) ===
# Prefer MODEL_CATALOG_PATH below — it overrides these three.
# DEEPSEEK_MODELS=deepseek-v4-pro,deepseek-v4-flash
# MIMO_MODELS=mimo-v2.5-pro                          # must be lowercase — MiMo model IDs are case-sensitive
# OPENAI_MODELS=                                     # empty = OpenAI routing is opt-in only

# === Optional: Model catalog (single source of truth) ===
# Point to the same proxy-models.json that Codex reads via model_catalog_json.
# See proxy-models.example.json in this repo for a starter file you can copy.
# The proxy infers provider from slug prefix (deepseek-* / mimo-* / gpt-* etc.)
# and overrides *_MODELS above.
# MODEL_CATALOG_PATH=~/.codex/proxy-models.json

# === Optional: Heuristic prefix routing ===
# Model names starting with any of these prefixes route to OpenAI (even if not in OPENAI_MODELS).
# OPENAI_MODEL_PREFIXES=gpt-,o1,o3,o4,codex-,chatgpt-

# === Optional: Redis store backend ===
# By default the response store (previous_response_id continuity) lives in an
# in-process LRU Map — zero dependencies, but lost on restart and not shared
# across instances. Set REDIS_URL to switch to Redis: survives restarts and is
# shared across replicas (enables horizontal scaling). Requires the `redis`
# package (auto-installed in the Docker image; run `npm install redis` for bare
# `node` runs). The bundled docker-compose.yml wires this automatically.
# REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:password@redis-host:6379/0

# === Optional: Compaction ===
# Model used for Codex remote compaction (POST /responses/compact). Summarizing
# doesn't need the flagship model and is latency-sensitive, so by default the
# proxy auto-picks a lighter variant the provider advertises (e.g. *-flash/-mini).
# Set this to pin an explicit model (must be one of the provider's configured models).
# COMPACT_MODEL=deepseek-v4-flash

# === Optional: Vision (image parsing for text-only models) ===
# Text-only upstreams (DeepSeek) 400 on images. The proxy always strips images to
# a placeholder so requests don't fail. If a vision model is configured below, it
# also exposes a silent `view_image` tool: the main model calls it with its own
# query and the image is analysed by the vision model in the background (like
# web_fetch). Defaults to the MiMo provider (mimo-v2.5) — set MIMO_API_KEY to
# enable, or point VISION_* elsewhere. With no key, images are simply dropped.
# VISION_MODEL=mimo-v2.5-pro
# VISION_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1   # defaults to MIMO_BASE_URL
# VISION_API_KEY=your-vision-key                            # defaults to MIMO_API_KEY
# VISION_MAX_TOKENS=2048

# === Optional: Logging ===
# LOG_LEVEL=info        # silent / error / warn / info (default) / debug
# ACCESS_LOG=0          # set to 0 to suppress per-request access logs

# === Optional: Timeouts / capacity (rarely need changing) ===
# UPSTREAM_TIMEOUT_MS=120000        # upstream chat/completions total timeout
# STORE_TTL_MS=3600000              # responseStore entry TTL
# STORE_MAX=500                     # responseStore LRU capacity
# MAX_CONSECUTIVE_TOOL_CALLS=20     # circuit breaker for runaway tool-call loops
# FETCH_TIMEOUT_MS=15000            # web_fetch non-GET single request timeout
# FETCH_MAX_BODY=50000              # web_fetch non-GET response body limit
# MAX_FETCH_LOOPS=5                 # web_fetch max nesting depth (prevents loops)
# JINA_BASE=https://r.jina.ai      # Jina Reader base URL for GET fetches
# JINA_FETCH_TIMEOUT_MS=20000
# JINA_MAX_BODY=80000
